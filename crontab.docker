# 투자봇 Docker 내부 스케줄러
# 타임존: Asia/Seoul (KST) — Dockerfile에서 설정됨
# /etc/cron.d/ 형식: 각 항목에 username 필드 필수
SHELL=/bin/bash
PATH=/usr/local/bin:/usr/bin:/bin

# alerts_watch: 5분마다 (launchd KeepAlive 대체 — run-once 스크립트)
*/5 * * * * root cd /app && python3 analysis/alerts_watch.py >> /app/logs/alerts_watch.log 2>&1

# Claude 크레덴셜 자동 동기화: 1분마다 (호스트 재로그인 후 60초 내 반영)
*/1 * * * * root cp /root/.claude-host/.credentials.json /root/.claude/.credentials.json 2>/dev/null || true

# 가격 갱신: 1분마다 (스크립트 내부에서 장중 여부 판단 — 장외엔 즉시 종료)
*/1 * * * * root cd /app && python3 scripts/refresh_prices.py >> /app/logs/refresh_prices.log 2>&1

# 마커스 AI 분석: 평일(월~금) 05:30 KST
30 5 * * 1-5 root cd /app && python3 scripts/run_marcus.py >> /app/logs/marcus.log 2>&1

# 자비스 분석: 평일(월~금) 07:30 KST
30 7 * * 1-5 root cd /app && python3 scripts/run_jarvis.py >> /app/logs/jarvis.log 2>&1

# 전체 파이프라인: 평일(월~금) 07:40 KST
40 7 * * 1-5 root cd /app && python3 run_pipeline.py >> /app/logs/pipeline.log 2>&1

# R2 동기화: 평일(월~금) 07:50 KST (파이프라인 07:40 완료 후)
50 7 * * 1-5 root cd /app && python3 scripts/sync_to_r2.py >> /app/logs/sync_r2.log 2>&1

# 블로그 발행: 평일(월~금) 07:55 KST
55 7 * * 1-5 root cd /app && python3 scripts/publish_blog.py >> /app/logs/publish_blog.log 2>&1

# 뉴스 수집: 평일(월~금) 08:00 KST
0 8 * * 1-5 root cd /app && python3 scripts/refresh_news.py >> /app/logs/news.log 2>&1

# 기업 프로필 사전 수집: 평일(월~금) 08:10 KST (파이프라인 07:40 완료 후)
10 8 * * 1-5 root cd /app && python3 data/fetch_company_profiles.py >> /app/logs/company_profiles.log 2>&1

# 시스템 헬스체크: 평일(월~금) 09:00 KST (모든 아침 잡 완료 후)
0 9 * * 1-5 root cd /app && python3 scripts/health_check.py >> /app/logs/health_check.log 2>&1

# 월별 입금 기록: 매월 1일 00:00 KST
0 0 1 * * root cd /app && python3 scripts/monthly_deposit_cron.py >> /app/logs/deposit.log 2>&1

# 태양광 매물 수집: 매일 08:30, 19:00 KST
30 8 * * * root cd /app && python3 scripts/refresh_solar.py >> /app/logs/refresh_solar.log 2>&1
0 19 * * * root cd /app && python3 scripts/refresh_solar.py >> /app/logs/refresh_solar.log 2>&1

# 유니버스 캐시 갱신: 매주 일요일 04:00 KST (value_screener PER/PBR/ROE 소스)
0 4 * * 0 root cd /app && python3 analysis/universe_cache.py >> /app/logs/universe_cache.log 2>&1

# DART 법인코드 갱신: 매월 1일 05:00 KST
0 5 1 * * root cd /app && python3 data/fetch_dart_corp_codes.py >> /app/logs/dart_corp_codes.log 2>&1

# 장마감 리포트: 평일(월~금) 16:00 KST
0 16 * * 1-5 root cd /app && python3 reports/closing.py >> /app/logs/closing.log 2>&1

# DB 유지보수 (purge + vacuum): 매주 일요일 03:00 KST
0 3 * * 0 root cd /app && python3 db/maintenance.py >> /app/logs/maintenance.log 2>&1

# 로그 로테이션: 매일 00:05 KST — 10MB 초과 로그 압축 + 7일 이상 삭제
5 0 * * * root find /app/logs -name "*.log" -size +10M -exec gzip {} \; && find /app/logs -name "*.log.gz" -mtime +7 -delete
